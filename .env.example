# Service
APP_ENV=local
AI_SERVICE_API_KEY=dev-ai-service-key
PILOT_BRANCH_ID=pilot-branch-001
LOG_LEVEL=INFO

# Gemini — optional, used as fallback if local model is unavailable or low-confidence
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Local ONNX vision model (primary provider)
VISION_PROVIDER=local_model
ENABLE_GEMINI_FALLBACK=true
MODEL_PATH=models/current/mobilenetv3_large_skin_ai.onnx
MODEL_LABELS_PATH=models/current/labels.json
MODEL_VERSION=genx-vision-v0.1
MODEL_THRESHOLD=0.65

# CRM integration
CRM_BASE_URL=
CRM_API_KEY=
CRM_TIMEOUT_SECONDS=15
PUSH_ANALYSIS_TO_CRM=false

# Storage
# Use PostgreSQL in pilot/prod, for example:
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/genx_ai
DATABASE_URL=sqlite:///./genx_ai.db

# Scheduler
ENABLE_SCHEDULER=false
RECOMMENDATION_CRON_HOUR=8

